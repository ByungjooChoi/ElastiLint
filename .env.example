# ElastiLint — copy this file to ".env" and fill in your own values.
# The .env file is gitignored. NEVER commit real credentials.

# Kibana endpoint of your Elastic Serverless project (trailing slash optional).
# Example: https://my-project-abc123.kb.us-west-2.aws.elastic.cloud
KIBANA_URL=

# Elastic API key with privileges to manage Agent Builder tools, agents,
# and Workflows. Paste the "encoded" key value (a single base64 string).
# Create one in Kibana: Stack Management -> API keys (or the Elasticsearch
# "Create API key" button). Use the least privilege that still works.
KIBANA_API_KEY=
